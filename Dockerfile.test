FROM node:20-slim

RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages/ packages/
COPY e2e/ e2e/
RUN pnpm install --frozen-lockfile
RUN pnpm build
# Worker bundle for Miniflare — separate dir to avoid tsup clean destroying dist/
RUN cd packages/server && npx tsup src/worker.ts --format esm --target es2022 --platform browser --no-dts --no-sourcemap --out-dir dist-worker

CMD ["pnpm", "vitest", "run", "--config", "e2e/docker/vitest.config.ts"]
